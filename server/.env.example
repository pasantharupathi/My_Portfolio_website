# ══════════════════════════════════════════════════════════
#   Portfolio Backend — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server Port ──────────────────────────────────────────
# Default: 5000. Change if port is already in use.
# On Render/Railway, PORT is set automatically — don't touch it.
PORT=5000
NODE_ENV=development

# ── Email (Gmail SMTP) ──────────────────────────────────
# Required for contact form emails to work.
#
# HOW TO CREATE A GMAIL APP PASSWORD:
# ─────────────────────────────────────
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" (required first)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select app: "Mail", device: "Other" → name it "Portfolio"
# 5. Click "Generate" — you'll get a 16-character password
# 6. Paste it below (with or without spaces)
#
# NOTE: This is NOT your Gmail password — it's a separate App Password.
#
EMAIL_USER=pasantharupathi1@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Optional: separate notification email (defaults to EMAIL_USER)
NOTIFY_EMAIL=pasantharupathi1@gmail.com

# ── GitHub Stats Proxy ──────────────────────────────────
# Optional: provides higher rate limits (5000 vs 60 req/hr)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=pasantharupathi

# ── Frontend URL (for CORS) ────────────────────────────
# Local development:
CLIENT_URL=http://localhost:5173

# HOW TO UPDATE AFTER DEPLOYMENT:
# ───────────────────────────────
# After deploying frontend to Vercel, change to:
# CLIENT_URL=https://your-portfolio.vercel.app
