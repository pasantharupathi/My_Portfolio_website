# ══════════════════════════════════════════════════════════
#   Portfolio Backend — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to Git — it is listed in .gitignore.

# ── Server Port ──────────────────────────────────────────
# Default: 5000. Change if port is already in use locally.
# On Render/Railway, PORT is set automatically — don't touch it.
PORT=5000
NODE_ENV=development

# ── Resend (Email Service) ───────────────────────────────
# Used to send contact form notifications and auto-replies.
#
# HOW TO GET A RESEND API KEY:
# ─────────────────────────────
# 1. Sign up at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Copy the key and paste it below
#
# ⚠️  Keep this secret — anyone with this key can send emails
#     from your verified domain.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address where contact form submissions are delivered.
# This should match your verified sender domain on Resend.
EMAIL_USER=your@email.com

# ── GitHub Stats Proxy ──────────────────────────────────
# Optional: provides higher API rate limits (5000 vs 60 req/hr)
# Create a token at: https://github.com/settings/tokens
# Only needs read:user and public_repo scopes.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=pasantharupathi

# ── Frontend URL (for CORS) ────────────────────────────
# Local development:
CLIENT_URL=http://localhost:5173

# HOW TO UPDATE AFTER DEPLOYMENT:
# ───────────────────────────────
# After deploying frontend to Vercel, change to:
# CLIENT_URL=https://your-portfolio.vercel.app
